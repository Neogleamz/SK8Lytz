<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-sdk tools:overrideLibrary="androidx.health.services.client" />

    <!-- Mark this APK as a Wear OS app -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Wearable Data Layer messaging (phone <-> watch) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Body sensors for heart rate via Health Services -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <!-- Vibrate for haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Required for OngoingActivity notifications on Wear OS 4+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="SK8Lytz"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">
        
        <uses-library android:name="com.google.android.wearable" android:required="true" />
        <meta-data android:name="com.google.android.wearable.standalone" android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WearableListenerService: receives messages/data from the phone app -->
        <service
            android:name=".services.WearableCommunicationService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:pathPrefix="/sk8lytz"
                    android:scheme="wear" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:host="*"
                    android:pathPrefix="/sk8lytz/state"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <!-- Tile Service — SK8Lytz tile in the watch tile carousel -->
        <service
            android:name=".tiles.Sk8lytzTileService"
            android:label="SK8Lytz"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@mipmap/ic_launcher" />
        </service>

        <!-- Required for Health Services ExerciseClient capabilities query -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />
    </application>
</manifest>
