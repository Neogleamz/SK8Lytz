#!/bin/sh
set -e
# Husky pre-commit hook — Worktree-safe
#
# Problem: When committing inside a git worktree, $CWD is the worktree directory
# which has no node_modules. npx tsc/jest would fail with "preset not found".
#
# Fix: Resolve the master fortress root via the shared git common-dir,
# then run all checks from there where node_modules lives.
#
# git rev-parse --git-common-dir returns the path to the shared .git dir.
# For the main repo it returns ".git"; for worktrees it returns the absolute path
# to the main repo's .git dir (e.g. /path/to/SK8Lytz/.git).
# We resolve the parent of that path as the fortress root.

COMMON_DIR=$(git rev-parse --git-common-dir)
if [ "$COMMON_DIR" = ".git" ]; then
  # Already in the master fortress
  FORTRESS_ROOT=$(git rev-parse --show-toplevel)
else
  # In a worktree — parent of the shared .git dir IS the fortress root
  FORTRESS_ROOT=$(dirname "$COMMON_DIR")
fi

WORKTREE_ROOT=$(pwd)

# Ensure node_modules junction exists if inside a worktree
if [ "$WORKTREE_ROOT" != "$FORTRESS_ROOT" ]; then
  if [ ! -d "node_modules" ]; then
    echo "[Husky] Creating node_modules directory junction..."
    WIN_FORTRESS_ROOT=$(cygpath -w "$FORTRESS_ROOT" || echo "$FORTRESS_ROOT")
    cmd.exe /c "mklink /j node_modules \"$WIN_FORTRESS_ROOT\\node_modules\""
  fi
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.\(ts\|tsx\|js\|jsx\)$' || true)

ABS_FILES=""
if [ -n "$STAGED_FILES" ]; then
  for file in $STAGED_FILES; do
    ABS_FILES="$ABS_FILES \"$WORKTREE_ROOT/$file\""
  done
fi

if [ -n "$ABS_FILES" ]; then
  echo "[Husky] Running Babel Syntax Gate..."
  export NODE_PATH="$WORKTREE_ROOT/node_modules"
  eval node "\"$WORKTREE_ROOT/scripts/babel-syntax-gate.js\"" $ABS_FILES

  echo "[Husky] Running ESLint on staged files..."
  eval npx eslint $ABS_FILES --max-warnings=0
fi

echo "[Husky] Running TSC check from: $WORKTREE_ROOT"
npx tsc --noEmit

echo "[Husky] Running Jest from: $WORKTREE_ROOT"
npx jest --watchAll=false --passWithNoTests
